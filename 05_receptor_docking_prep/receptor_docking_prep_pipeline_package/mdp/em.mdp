define                  = -DPOSRES_BB

integrator              = steep
emtol                   = 100
emstep                  = 0.01
nsteps                  = 50000

cutoff-scheme           = Verlet

coulombtype             = PME
rcoulomb                = 1.0

vdwtype                 = Cut-off
rvdw                    = 1.0

constraints             = h-bonds
pbc                     = xyz